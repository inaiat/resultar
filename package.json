{
  "name": "resultar",
  "version": "1.4.5",
  "description": "Result pattern for typescript",
  "keywords": [
    "plugin"
  ],
  "homepage": "https://github.com/inaiat/resultar",
  "bugs": {
    "url": "https://github.com/inaiat/resultar/issues"
  },
  "license": "MIT",
  "author": "inaiat@gmail.com",
  "contributors": [
    "Inaiat <inaiat@gmail.com>",
    "Tomaz Haidar <tomaz_haidar@hotmail.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inaiat/resultar.git"
  },
  "directories": {
    "test": "test"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vp pack",
    "check": "vp check",
    "check:full": "vp check && vp test run --coverage",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "prepublishOnly": "pnpm run build",
    "test": "vp test",
    "test:watch": "vp test watch",
    "test:ui": "vp test --ui --watch",
    "test:cov": "vp test run --coverage",
    "typedoc": "typedoc",
    "prepare": "vp config || true",
    "bench": "pnpm run build && node --import tsx benchmarks/resultar-vs-neverthrow.ts",
    "bench:neverthrow": "pnpm run bench"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "cronometro": "^6.0.3",
    "neverthrow": "^8.2.0",
    "tsx": "^4.21.0",
    "typedoc": "0.28.19",
    "typedoc-github-wiki-theme": "~2.1.0",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.2",
    "vite-plus": "0.1.18"
  },
  "release": {
    "branches": [
      {
        "name": "main"
      },
      {
        "name": "beta",
        "channel": "beta",
        "prerelease": true
      },
      {
        "name": "next",
        "channel": "channel-next"
      }
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2",
  "licenses": [
    {
      "type": "MIT",
      "url": "http://opensource.org/licenses/MIT"
    }
  ]
}
